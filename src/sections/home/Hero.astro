---
import { Image } from 'astro:assets';
import rotasiImg from '../../assets/images/rotasi.png';
import maskotImg from '../../assets/images/Maskot_CE-removebg-preview.png';
import coreldrawImg from '../../assets/images/coreldraw.png';
import codingImg from '../../assets/images/coding.png';
import videoImg from '../../assets/images/video.png';
import cameraaImg from '../../assets/images/cameraa.png';
---
<!-- Hero Section -->
<section class="relative min-h-screen w-full overflow-hidden pt-30 pb-20" id="home">
    <!-- Background Hexagons -->
    <div class="contener">
        <div class="curser"></div>
        {Array.from({ length: 7 }).map((_) => (
            <div class="row">
                {Array.from({ length: 13 }).map((_) => (
                    <div class="hexagon"></div>
                ))}
            </div>
        ))}
    </div>

    <!-- Content Grid -->
    <div class="relative z-10 container mx-auto grid h-full items-center gap-12 px-6 md:grid-cols-2 md:px-12">
        <!-- Left Column: Text -->
        <div class="space-y-6 text-center md:text-left">
            <h1
                class="bg-gradient-to-br from-green-600 to-emerald-400 bg-clip-text text-4xl font-extrabold tracking-tight text-transparent uppercase drop-shadow-sm md:text-6xl">
                Welcome to
                <br />
                <span class="text-gray-800 dark:text-white">Computer Education</span>
            </h1>
            <p class="text-xl font-medium text-gray-600 dark:text-gray-300 md:text-2xl">Salam Teknologi. Innovate, Create, and Inspire.</p>
            <div class="flex justify-center md:justify-start">
                <a
                    href="#learning"
                    class="transform rounded-full bg-green-600 px-8 py-3 font-semibold text-white shadow-lg transition hover:scale-105 hover:bg-green-700">
                    Start Learning
                </a>
            </div>
        </div>

        <!-- Right Column: Visuals (Mascot & Floating Icons) -->
        <div class="relative flex h-[400px] items-center justify-center md:h-[500px]">
            <!-- Rotating Background behind Mascot -->
            <Image
                src={rotasiImg}
                class="rotasi-img absolute w-[300px] opacity-80 md:w-[450px]"
                alt="Rotating Background" />

            <!-- Mascot -->
            <Image
                src={maskotImg}
                class="logo-mantul relative z-20 w-[200px] drop-shadow-2xl md:w-[280px]"
                alt="Mascot CE" />

            <!-- Floating Icons (Positioned relative to this column) -->
            <!-- CorelDraw -->
            <div class="animasi-satu absolute top-0 left-0 z-30 md:left-10">
                <Image src={coreldrawImg} class="h-16 w-16 drop-shadow-lg md:h-20 md:w-20" alt="CorelDraw" />
            </div>

            <!-- Coding -->
            <Image
                src={codingImg}
                class="animasi-2 absolute bottom-10 left-0 z-30 h-14 w-14 drop-shadow-lg md:left-10 md:h-16 md:w-16"
                alt="Coding" />

            <!-- Video -->
            <Image
                src={videoImg}
                class="animasi-3 absolute right-0 bottom-20 z-30 h-14 w-14 drop-shadow-lg md:right-10 md:h-16 md:w-16"
                alt="Video" />

            <!-- Camera -->
            <Image
                src={cameraaImg}
                class="animasi-4 absolute top-10 right-0 z-30 h-14 w-14 drop-shadow-lg md:right-5 md:h-16 md:w-16"
                alt="Camera" />
        </div>
    </div>
</section>
