---
import { Image } from 'astro:assets';
import logoImg from '../assets/images/logo.png';
import { footerMenus } from '../menus';
import socialData from '../content/social.json';
---

<footer class="relative overflow-hidden bg-gradient-to-br from-green-900 to-gray-900 pt-20 pb-10 text-white">
    <!-- Abstract Background Shape (Optional) -->
    <div
        class="pointer-events-none absolute top-0 right-0 h-96 w-96 translate-x-1/3 -translate-y-1/2 rounded-full bg-green-500/10 blur-3xl"></div>

    <div class="relative z-10 container mx-auto px-6 md:px-12">
        <div class="mb-16 grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-4">
            <!-- Column 1: Brand Info -->
            <div class="space-y-6">
                <a href="/" class="flex items-center gap-3">
                    <Image class="h-12 w-auto brightness-0 invert" src={logoImg} alt="Logo CE" />
                </a>
                <p class="text-sm leading-relaxed text-green-100/80">
                    Wadah mahasiswa untuk berkreasi, berinovasi, dan berkontribusi membangun kampus yang lebih baik
                    melalui teknologi.
                </p>
                <div class="flex gap-4">
                    <a
                        href={socialData.instagram || "#"}
                        class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 transition-all duration-300 hover:scale-110 hover:bg-green-500">
                        <i class="fa-brands fa-instagram text-lg"></i>
                    </a>
                    <a
                        href={socialData.youtube || "#"}
                        class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 transition-all duration-300 hover:scale-110 hover:bg-green-500">
                        <i class="fa-brands fa-youtube text-lg"></i>
                    </a>
                    <a
                        href={socialData.tiktok || "#"}
                        class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 transition-all duration-300 hover:scale-110 hover:bg-green-500">
                        <i class="fa-brands fa-tiktok text-lg"></i>
                    </a>
                </div>
            </div>

            <!-- Column 2: Quick Links -->
            <div>
                <h3 class="mb-6 text-lg font-bold text-green-400">Jelajahi</h3>
                <ul class="space-y-4">
                    {footerMenus.map((menu) => (
                        <li>
                            <a href={menu.href} class="text-green-100/70 transition-all duration-300 hover:pl-2 hover:text-white">
                                {menu.name}
                            </a>
                        </li>
                    ))}
                </ul>
            </div>

            <!-- Column 3: Contact Info -->
            <div>
                <h3 class="mb-6 text-lg font-bold text-green-400">Hubungi Kami</h3>
                <ul class="space-y-4 text-green-100/80">
                    <li class="flex items-start gap-3">
                        <i class="fa-solid fa-location-dot mt-1 text-green-500"></i>
                        <span> Jl. Fatahillah No. 10, Kabupaten Cirebon (Universitas Muhammadiyah Cirebon) </span>
                    </li>
                    <li class="flex items-center gap-3">
                        <i class="fa-solid fa-envelope text-green-500"></i>
                        <span>computer_education@umc.ac.id</span>
                    </li>
                    <li class="flex items-center gap-3">
                        <i class="fa-brands fa-whatsapp text-green-500"></i>
                        <span>+62 812-9130-0572</span>
                    </li>
                </ul>
            </div>

            <!-- Column 4: WhatsApp Action -->
            <div>
                <h3 class="mb-6 text-lg font-bold text-green-400">Tanya Admin</h3>
                <p class="mb-4 text-sm text-green-100/70">
                    Punya pertanyaan seputar organisasi atau materi? Kirim pesan langsung.
                </p>
                <form id="wa-form" class="space-y-3">
                    <div class="relative">
                        <input
                            id="pesan"
                            type="text"
                            required
                            placeholder="Tulis pesan..."
                            class="w-full rounded-lg border border-green-500/30 bg-white/10 px-4 py-3 text-white placeholder-green-100/30 transition-all focus:border-green-500 focus:outline-none" />
                    </div>
                    <button
                        type="submit"
                        class="flex w-full items-center justify-center gap-2 rounded-lg bg-gradient-to-r from-green-600 to-green-500 py-3 font-semibold shadow-lg shadow-green-900/50 transition-all duration-300 hover:from-green-500 hover:to-green-400 hover:shadow-green-500/30">
                        <span>Kirim WhatsApp</span>
                        <i class="fa-brands fa-whatsapp"></i>
                    </button>
                </form>
            </div>
        </div>

        <!-- Divider -->
        <div class="flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 md:flex-row">
            <p class="text-sm text-green-100/40">
                &copy; {new Date().getFullYear()} Computer Education UMC. All rights reserved.
            </p>
            <div class="flex gap-6 text-sm text-green-100/40">
                <a href="#" class="transition hover:text-white"> Privacy Policy </a>
                <a href="#" class="transition hover:text-white"> Terms of Service </a>
            </div>
        </div>
    </div>
</footer>

<script define:vars={{ waNumber: socialData.whatsapp }}>
    const waForm = document.getElementById('wa-form');
    if (waForm) {
        waForm.addEventListener('submit', function(e) {
            e.preventDefault();
            const pesanInput = document.getElementById('pesan');
            if (pesanInput) {
                const pesan = pesanInput.value;
                const nomorWA = waNumber || '6281291300572';
                const waText = `Halo Admin Computer Education, saya ingin bertanya: ${pesan}`;
                const url = `https://wa.me/${nomorWA}?text=${encodeURIComponent(waText)}`;
                window.open(url, '_blank');
            }
        });
    }
</script>
