---
interface Props {
    toc: any[];
}

const { toc } = Astro.props;
---

{toc.length > 0 && (
    <aside class="sticky top-[90px] hidden w-64 shrink-0 flex-col gap-4 overflow-y-auto border-l border-gray-100 dark:border-gray-800 pb-10 pl-6 xl:flex transition-colors duration-300" style="max-height: calc(100vh - 90px);">
        <h4 class="text-sm font-bold tracking-wider text-gray-900 dark:text-white uppercase pt-2">Daftar Isi</h4>
        <nav class="flex flex-col gap-3 border-l-2 border-gray-100 dark:border-gray-800 ml-1">
            {toc.map((h: any) => (
                <a href={`#${h.slug}`} class={`toc-link text-sm text-gray-500 dark:text-gray-400 hover:text-green-600 dark:hover:text-green-500 transition-colors relative -left-[2px] border-l-2 border-transparent hover:border-green-500 pl-4 py-1 ${h.depth === 3 ? 'ml-4' : 'font-medium'}`}>
                    {h.text}
                </a>
            ))}
        </nav>
    </aside>
)}
