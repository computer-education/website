---
interface Props {
    prevModule: any;
    nextModule: any;
}

const { prevModule, nextModule } = Astro.props;
---

<div class="mt-16 flex flex-col sm:flex-row items-center justify-between gap-4 border-t border-gray-100 dark:border-gray-800 pt-8 transition-colors duration-300">
    {prevModule ? (
        <a href={`/learning/${prevModule.id}`} class="group flex w-full sm:w-1/2 flex-col items-start gap-1 rounded-xl border border-gray-100 dark:border-gray-800 p-4 transition-all hover:border-green-500 hover:bg-green-50 dark:hover:bg-green-900/30 hover:-translate-x-1">
            <span class="text-xs font-semibold text-gray-400 dark:text-gray-500 group-hover:text-green-600 dark:group-hover:text-green-500 uppercase tracking-wider flex items-center gap-1">
                <i class="ph ph-arrow-left"></i> Sebelumnya
            </span>
            <span class="font-medium text-gray-900 dark:text-white group-hover:text-green-700 dark:group-hover:text-green-400 text-left line-clamp-1">{prevModule.title || prevModule.data?.title}</span>
        </a>
    ) : (
        <div class="hidden sm:block w-full sm:w-1/2"></div>
    )}
    
    {nextModule ? (
        <a href={`/learning/${nextModule.id}`} class="group flex w-full sm:w-1/2 flex-col items-end gap-1 rounded-xl border border-gray-100 dark:border-gray-800 p-4 transition-all hover:border-green-500 hover:bg-green-50 dark:hover:bg-green-900/30 hover:translate-x-1 text-right">
            <span class="text-xs font-semibold text-gray-400 dark:text-gray-500 group-hover:text-green-600 dark:group-hover:text-green-500 uppercase tracking-wider flex items-center gap-1">
                Selanjutnya <i class="ph ph-arrow-right"></i>
            </span>
            <span class="font-medium text-gray-900 dark:text-white group-hover:text-green-700 dark:group-hover:text-green-400 line-clamp-1">{nextModule.title || nextModule.data?.title}</span>
        </a>
    ) : (
        <div class="hidden sm:block w-full sm:w-1/2"></div>
    )}
</div>
