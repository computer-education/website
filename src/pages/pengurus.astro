---
import Layout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allPengurus = await getCollection('pengurus');

// Group by urutan
const grouped = allPengurus.reduce((acc, current) => {
    const urutan = current.data.urutan || 99;
    if (!acc[urutan]) {
        acc[urutan] = [];
    }
    acc[urutan].push(current);
    return acc;
}, {} as Record<number, typeof allPengurus>);

const urutanKeys = Object.keys(grouped).map(Number).sort((a, b) => a - b);
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/pengurus/*.{jpeg,jpg,png,gif,webp}');
---

<Layout title="Struktur Organisasi | Computer Education">
    <!-- Hero Section -->
    <section class="relative bg-white dark:bg-gray-950 pt-[100px] pb-16 transition-colors duration-300 overflow-hidden">
        <div class="absolute inset-0 bg-[url('/pattern.svg')] opacity-5 dark:opacity-10"></div>
        <div class="absolute -top-40 -left-40 h-96 w-96 rounded-full bg-blue-500/10 blur-3xl dark:bg-blue-500/20"></div>
        <div class="absolute top-10 -right-40 h-72 w-72 rounded-full bg-emerald-500/10 blur-3xl dark:bg-emerald-500/20"></div>

        <div class="container relative mx-auto px-6 max-w-4xl text-center">
            <span class="inline-block rounded-full bg-blue-100 dark:bg-blue-900/30 px-4 py-1.5 text-sm font-bold tracking-wider text-blue-700 dark:text-blue-400 uppercase mb-6 shadow-sm border border-blue-200 dark:border-blue-800">
                Kabinet Pengurus
            </span>
            <h1 class="text-4xl font-extrabold text-gray-900 dark:text-white md:text-5xl mb-6">
                Tim Hebat di Balik <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-emerald-500">CE</span>
            </h1>
            <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto leading-relaxed">
                Menyajikan struktur kepengurusan secara hierarkis, menggerakkan roda organisasi untuk terus maju dan berinovasi.
            </p>
        </div>
    </section>

    <main class="bg-gray-50 dark:bg-gray-900 py-20 transition-colors duration-300 min-h-screen">
        <div class="container mx-auto px-6 max-w-7xl">
            
            <div class="flex flex-col items-center">
                {urutanKeys.map((urutan, index) => {
                    const pengurusList = grouped[urutan];
                    const isLast = index === urutanKeys.length - 1;

                    return (
                        <div class="w-full flex flex-col items-center relative mb-12 md:mb-16">
                            <!-- Group of Cards -->
                            <div class="flex flex-wrap justify-center gap-4 md:gap-6 w-full z-10">
                                {pengurusList.map((p) => {
                                    const imgPath = p.data.foto ? `/src/assets/images/pengurus/${p.data.foto.split('/').pop()}` : null;
                                    const imageSrc = imgPath && images[imgPath] ? images[imgPath]() : null;
                                    
                                    return (
                                        <div class="group relative flex flex-col items-center bg-white dark:bg-gray-950 p-5 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 hover:shadow-xl transition-all duration-300 hover:-translate-y-1.5 w-full sm:w-[220px] md:w-[240px]">
                                            
                                            <div class="w-24 h-24 md:w-28 md:h-28 rounded-full mb-4 bg-gray-50 dark:bg-gray-900 shadow-inner overflow-hidden ring-4 ring-gray-50 dark:ring-gray-800 group-hover:ring-blue-100 dark:group-hover:ring-blue-900/30 transition-all duration-500 relative flex-shrink-0">
                                                {imageSrc ? (
                                                    <Image src={imageSrc} alt={p.data.nama} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                                                ) : (
                                                    <div class="w-full h-full flex items-center justify-center text-gray-300 dark:text-gray-600">
                                                        <i class="ph-fill ph-user text-4xl"></i>
                                                    </div>
                                                )}
                                                <div class="absolute inset-0 ring-inset ring-1 ring-black/5 dark:ring-white/5 rounded-full"></div>
                                            </div>
                                            
                                            <div class="text-center w-full">
                                                <h3 class="font-bold text-gray-900 dark:text-white text-[15px] md:text-base leading-tight mb-1.5 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-2">
                                                    {p.data.nama}
                                                </h3>
                                                <p class="text-[11px] md:text-xs font-bold text-emerald-600 dark:text-emerald-500 uppercase tracking-wider">
                                                    {p.data.jabatan}
                                                </p>
                                            </div>
                                        </div>
                                    )
                                })}
                            </div>

                            <!-- Subtle horizontal separator linking to the next level -->
                            {!isLast && (
                                <div class="w-full flex justify-center mt-12 md:mt-16 opacity-40 dark:opacity-30">
                                    <i class="ph-bold ph-caret-down text-3xl text-gray-400 dark:text-gray-500 animate-bounce"></i>
                                </div>
                            )}
                        </div>
                    )
                })}

                {urutanKeys.length === 0 && (
                    <div class="text-center py-20 text-gray-500 dark:text-gray-400 w-full bg-white dark:bg-gray-950 rounded-3xl border border-gray-100 dark:border-gray-800 border-dashed">
                        <i class="ph ph-users text-6xl mb-4 opacity-50"></i>
                        <p class="text-xl font-medium">Data Pengurus Belum Tersedia.</p>
                        <p class="text-sm mt-2 opacity-80">Silakan tambahkan anggota organisasi melalui CMS Keystatic.</p>
                    </div>
                )}
            </div>
            
        </div>
    </main>
</Layout>
